    "persistence",
    "context",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "tiktoken": "^1.0.18",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
