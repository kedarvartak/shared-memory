  "description": "MCP server for token-efficient, persistent AI memory using LLM reasoning (PageIndex-inspired) across conversations and IDEs",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "shared-memory-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
