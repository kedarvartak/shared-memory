{
  "name": "shared-memory-mcp",
  "version": "3.0.0",
  "description": "MCP server for persistent, portable AI memory across conversations and IDEs. Cross-conversation memory with token-efficient CCL format.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "shared-memory-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "test": "echo \"Run: npx shared-memory-mcp\" && exit 0",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "claude",
    "cursor",
    "persistent-memory",
    "cross-conversation",
    "ccl",
    "ai-context",
    "model-context-protocol",
    "llm-memory",
    "conversation-memory",
    "context",
    "llm"
  ],
  "author": "Kedar Vartak <kedarvartak@example.com>",
  "license": "MIT",
  "homepage": "https://github.com/kedarvartak/shared-memory#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kedarvartak/shared-memory.git"
  },
  "bugs": {
    "url": "https://github.com/kedarvartak/shared-memory/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "tiktoken": "^1.0.18",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
